model AccountType {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   // "Cash", "Bank Account", "Crypto Wallet", etc.
  icon        String?  // Lucide icon name
  color       String?  // Display color
  isDefault   Boolean  @default(false) // System default types
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  
  // System types cannot be edited/deleted
  isSystem    Boolean  @default(false)
  
  // Relationships
  userId      String?  @db.ObjectId // Null for system types
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts    Account[]
  
  @@unique([userId, name])
  @@index([userId])
  @@map("account_types")
}

model Account {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  name        String      // "Main Wallet", "Travel Fund", etc.
  balance     Float       @default(0)
  currency    String?
  isDefault   Boolean     @default(false)
  notes       String?
  
  // Relationships
  userId      String      @db.ObjectId
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountTypeId String    @db.ObjectId
  accountType   AccountType @relation(fields: [accountTypeId], references: [id])
  transactions Transaction[]
  recurringTxns RecurringTransaction[]
  
  @@index([userId])
  @@index([accountTypeId])
  @@map("accounts")
}