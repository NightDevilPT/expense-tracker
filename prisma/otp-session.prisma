// prisma/models/otpSession.prisma

model OTPSession {
  id          String   @id @default(cuid())
  email       String
  otpCode     String
  expiresAt   DateTime
  verifiedAt  DateTime?
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())
  deletedAt   DateTime?
  
  @@index([email])
  @@index([expiresAt])
  @@index([deletedAt])
  @@map("otp_sessions")
}