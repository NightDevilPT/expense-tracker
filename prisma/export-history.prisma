// prisma/models/exportHistory.prisma

model ExportHistory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  format      String
  dateRange   Json
  filters     Json?
  fileUrl     String?
  fileSize    Int?
  exportedAt  DateTime @default(now())
  
  // Relationships
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([exportedAt])
  @@map("export_history")
}