// prisma/models/tag.prisma

model Tag {
  id          String   @id @default(cuid())
  name        String
  color       String?
  
  // Relationships
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions TransactionTag[]
  
  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}